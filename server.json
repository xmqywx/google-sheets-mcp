{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.xmqywx/google-sheets",
  "description": "MCP server for Google Sheets — read, write, format, and manage spreadsheets.",
  "repository": {
    "url": "https://github.com/xmqywx/google-sheets-mcp",
    "source": "github"
  },
  "version": "1.0.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@xmqywxkris/google-sheets-mcp",
      "version": "1.0.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Google API credentials JSON content",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "GOOGLE_CREDENTIALS"
        }
      ]
    }
  ]
}
